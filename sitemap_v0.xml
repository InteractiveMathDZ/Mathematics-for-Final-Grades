---
layout: null
---
<?xml version="1.0" encoding="UTF-8"?>
<urlset xmlns="http://www.sitemaps.org/schemas/sitemap/0.9">
  
  <url>
    <loc>https://interactivemathdz.github.io/Mathematics-for-Final-Grades/</loc>
    <priority>1.0</priority>
  </url>
  
  {% for doc in site.documents %}
    {% if doc.url %}
    <url>
      {% assign doc_url_clean = doc.url | replace: '//', '/' %}
      {% comment %} التحقق من آخر حرف في الرابط باستخدام فلتر slice {% endcomment %}
      {% assign last_char = doc_url_clean | slice: -1 %}
      {% if last_char != '/' %}
        {% assign doc_url_clean = doc_url_clean | append: '/' %}
      {% endif %}
      <loc>https://interactivemathdz.github.io/Mathematics-for-Final-Grades{{ doc_url_clean }}</loc>
      <priority>0.8</priority>
    </url>
    {% endif %}
  {% endfor %}

  {% for page in site.pages %}
    {% if page.url and page.url != "/404.html" and page.url != "/sitemap.xml" and page.url != "/sitemap_v2.xml" and page.url != "/sitemap_grades.xml" %}
    <url>
      {% assign page_url_clean = page.url | replace: '//', '/' %}
      {% if page_url_clean == '/' or page_url_clean == '' %}
        <loc>https://interactivemathdz.github.io/Mathematics-for-Final-Grades/</loc>
      {% else %}
        {% assign last_char_page = page_url_clean | slice: -1 %}
        {% comment %} إذا كان الرابط لا ينتهي بشرطة ولا يحتوي على امتداد ملف، نضيف الشرطة المائلة {% endcomment %}
        {% unless last_char_page == '/' or page_url_clean contains '.html' or page_url_clean contains '.xml' %}
          {% assign page_url_clean = page_url_clean | append: '/' %}
        {% endunless %}
        <loc>https://interactivemathdz.github.io/Mathematics-for-Final-Grades{{ page_url_clean }}</loc>
      {% endif %}
      <priority>0.8</priority>
    </url>
    {% endif %}
  {% endfor %}

</urlset>
