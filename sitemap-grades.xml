---
layout: null
---
<?xml version="1.0" encoding="UTF-8"?>
<urlset xmlns="http://www.sitemaps.org/schemas/sitemap/0.9">
  
  <url>
    <loc>https://interactivemathdz.github.io/Mathematics-for-Final-Grades/</loc>
    <priority>1.0</priority>
  </url>
  
  {% for doc in site.documents %}
    {% if doc.url %}
      {% comment %} إزالة الشرطة المائلة من نهاية البرمالنك إن وجدت ثم إضافة امتداد html {% endcomment %}
      {% assign clean_url = doc.url %}
      {% if doc.url endswith '/' %}
        {% assign clean_url = doc.url | replace_regexp: '\/$', '' %}
      {% endif %}
      <url>
        <loc>https://interactivemathdz.github.io/Mathematics-for-Final-Grades{{ clean_url }}.html</loc>
        <priority>0.8</priority>
      </url>
    {% endif %}
  {% endfor %}

  {% for page in site.pages %}
    {% if page.url and page.url != "/404.html" and page.url != "/sitemap.xml" %}
      {% assign page_clean = page.url %}
      {% if page.url endswith '/' %}
        {% assign page_clean = page.url | replace_regexp: '\/$', '' %}
      {% endif %}
      <url>
        <loc>https://interactivemathdz.github.io/Mathematics-for-Final-Grades{{ page_clean }}.html</loc>
        <priority>0.8</priority>
      </url>
    {% endif %}
  {% endfor %}

</urlset>
