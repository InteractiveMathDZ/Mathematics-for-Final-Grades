---
layout: null
---
<?xml version="1.0" encoding="UTF-8"?>
<urlset xmlns="http://www.sitemaps.org/schemas/sitemap/0.9">
  
  <url>
    <loc>https://interactivemathdz.github.io/Mathematics-for-Final-Grades/</loc>
    <priority>1.0</priority>
  </url>
  
  {% for doc in site.documents %}
    {% if doc.url %}
    <url>
      {% comment %} تحويل الروابط التي تنتهي بشرطة مائلة / إلى .html تلقائياً {% endcomment %}
      {% if doc.url text.endswith == '/' or doc.url_path or doc.url != '/' %}
        {% assign clean_url = doc.url | replace: '//', '/' %}
        {% if clean_url text.endswith == '/' %}
          {% comment %} إزالة الشرطة الأخيرة وإضافة الامتداد {% endcomment %}
          {% assign length = clean_url | size | minus: 1 %}
          {% assign clean_url = clean_url | slice: 0, length | append: '.html' %}
        {% endif %}
      {% else %}
        {% assign clean_url = doc.url %}
      {% endif %}
      <loc>https://interactivemathdz.github.io/Mathematics-for-Final-Grades{{ clean_url }}</loc>
      <priority>0.8</priority>
    </url>
    {% endif %}
  {% endfor %}

  {% for page in site.pages %}
    {% if page.url and page.url != "/404.html" and page.url != "/sitemap.xml" and page.url != "/sitemap_grades.xml" %}
    <url>
      {% if page.url contains '.' %}
        {% assign clean_page_url = page.url %}
      {% else %}
        {% assign clean_page_url = page.url | append: '.html' | replace: '/.html', '.html' %}
      {% endif %}
      <loc>https://interactivemathdz.github.io/Mathematics-for-Final-Grades{{ clean_page_url }}</loc>
      <priority>0.8</priority>
    </url>
    {% endif %}
  {% endfor %}

</urlset>
